<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.schedule.mapper.ConflictRecordMapper">
    <insert id="insert">
        INSERT INTO conflict_record(schedule_id,conflict_schedule_id,conflict_type)
        VALUES(#{scheduleId},#{conflictScheduleId},#{conflictType})
    </insert>
</mapper>