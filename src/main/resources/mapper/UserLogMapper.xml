<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.schedule.mapper.UserLogMapper">
    <insert id="insert">
        INSERT INTO user_operate_log(user_id,schedule_id,operate_type,operate_content)
        VALUES(#{userId},#{scheduleId},#{operateType},#{operateContent})
    </insert>
</mapper>
