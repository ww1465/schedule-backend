<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.schedule.mapper.UserMapper">

    <select id="findUserByOpenid" resultType="com.schedule.entity.User">
        SELECT id,username,password,nickname,email,create_time,openid
        FROM user WHERE openid = #{openid}
    </select>

    <insert id="insertWxUser">
        INSERT INTO user(username,password,nickname,openid,email,create_time)
        VALUES(#{username},#{password},#{nickname},#{openid},#{email},#{createTime})
    </insert>

</mapper>